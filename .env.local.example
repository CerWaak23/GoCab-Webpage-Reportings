# ============================================================
# GoCab Webapp — Variables de Entorno
# Copia este archivo a .env.local para desarrollo local.
# En Vercel, agrega estas variables en Settings → Environment Variables.
# ============================================================

# ----- NextAuth -----
# Clave secreta para firmar las sesiones. Genera una en:
# https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=cambia-esto-por-un-secreto-largo

# URL de tu app. En producción: tu dominio de Vercel.
# En local: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ----- Google OAuth -----
# Crea credenciales en: https://console.cloud.google.com
# Tipo: "ID de cliente OAuth 2.0" → Aplicación web
# Authorized redirect URIs:
#   - http://localhost:3000/api/auth/callback/google  (desarrollo)
#   - https://TU-DOMINIO.vercel.app/api/auth/callback/google  (producción)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

# ----- IDs de reportes en Google Drive -----
# Google Drive file ID del reporte de Bills (export-2580-bills.xlsx)
BILLS_FILE_ID=15kFa6-8xuOzvJw9rCSprh52L7E